<Window x:Class="LibraryManagement.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Библиотека книг" 
        Height="600" Width="900" 
        MinHeight="500" MinWidth="800"
        WindowStartupLocation="CenterScreen">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Панель фильтрации -->
        <WrapPanel Grid.Row="0" Margin="0,0,0,10">
            <TextBlock Text="Поиск:" VerticalAlignment="Center" Margin="5,0"/>
            <TextBox Width="200" Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" 
                     Margin="5,0" Padding="3"/>

            <TextBlock Text="Автор:" VerticalAlignment="Center" Margin="15,0,5,0"/>
            <ComboBox Width="150" ItemsSource="{Binding Authors}" 
                      SelectedItem="{Binding SelectedAuthorFilter}" 
                      DisplayMemberPath="LastName" Margin="5,0" Padding="3"/>

            <TextBlock Text="Жанр:" VerticalAlignment="Center" Margin="15,0,5,0"/>
            <ComboBox Width="150" ItemsSource="{Binding Genres}" 
                      SelectedItem="{Binding SelectedGenreFilter}" 
                      DisplayMemberPath="Name" Margin="5,0" Padding="3"/>

            <Button Content="Сбросить фильтры" Click="ResetFilters_Click" 
                    Margin="15,0,0,0" Padding="10,3"/>
        </WrapPanel>

        <!-- Таблица книг -->
        <DataGrid Grid.Row="1" 
                  ItemsSource="{Binding Books}" 
                  SelectedItem="{Binding SelectedBook}"
                  AutoGenerateColumns="False" 
                  IsReadOnly="True" 
                  SelectionMode="Single"
                  Margin="0,0,0,10">
            <DataGrid.Columns>
                <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="50"/>
                <DataGridTextColumn Header="Название" Binding="{Binding Title}" Width="250"/>
                <DataGridTextColumn Header="Автор" Binding="{Binding Author.LastName}" Width="120"/>
                <DataGridTextColumn Header="Жанр" Binding="{Binding Genre.Name}" Width="120"/>
                <DataGridTextColumn Header="Год" Binding="{Binding PublishYear}" Width="70"/>
                <DataGridTextColumn Header="ISBN" Binding="{Binding ISBN}" Width="120"/>
                <DataGridTextColumn Header="В наличии" Binding="{Binding QuantityInStock}" Width="80"/>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Панель кнопок (всегда видна) -->
        <WrapPanel Grid.Row="2" HorizontalAlignment="Right">
            <Button Content="Добавить книгу" Command="{Binding AddBookCommand}" 
                    Width="120" Height="30" Margin="5"/>
            <Button Content="Редактировать" Command="{Binding EditBookCommand}" 
                    Width="100" Height="30" Margin="5"/>
            <Button Content="Удалить" Command="{Binding DeleteBookCommand}" 
                    Width="80" Height="30" Margin="5"/>
            <Button Content="Управление авторами" Command="{Binding ManageAuthorsCommand}" 
                    Width="150" Height="30" Margin="5"/>
            <Button Content="Управление жанрами" Command="{Binding ManageGenresCommand}" 
                    Width="150" Height="30" Margin="5"/>
        </WrapPanel>
    </Grid>
</Window>