<Window x:Class="LibraryManagement.Views.GenresWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Управление жанрами" Height="450" Width="600"
        MinHeight="400" MinWidth="500"
        WindowStartupLocation="CenterOwner">

    <DockPanel Margin="10">
        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,10">
            <Button Content="Добавить" Command="{Binding AddCommand}" 
                    Width="80" Height="30" Margin="5"/>
            <Button Content="Удалить" Command="{Binding DeleteCommand}" 
                    Width="80" Height="30" Margin="5"/>
            <Button Content="Сохранить" Command="{Binding SaveCommand}" 
                    Width="80" Height="30" Margin="5"/>
        </StackPanel>

        <DataGrid ItemsSource="{Binding Genres}" 
                  SelectedItem="{Binding SelectedGenre}"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  Margin="0,0,0,10">
            <DataGrid.Columns>
                <DataGridTextColumn Header="ID" Binding="{Binding Id}" IsReadOnly="True"/>
                <DataGridTextColumn Header="Название" Binding="{Binding Name}"/>
                <DataGridTextColumn Header="Описание" Binding="{Binding Description}"/>
            </DataGrid.Columns>
        </DataGrid>
    </DockPanel>
</Window>