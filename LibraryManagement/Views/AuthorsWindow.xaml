<Window x:Class="LibraryManagement.Views.AuthorsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Управление авторами" Height="450" Width="600"
        MinHeight="400" MinWidth="500"
        WindowStartupLocation="CenterOwner">

    <DockPanel Margin="10">
        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,10">
            <Button Content="Добавить" Command="{Binding AddCommand}" 
                    Width="80" Height="30" Margin="5"/>
            <Button Content="Удалить" Command="{Binding DeleteCommand}" 
                    Width="80" Height="30" Margin="5"/>
            <Button Content="Сохранить" Command="{Binding SaveCommand}" 
                    Width="80" Height="30" Margin="5"/>
        </StackPanel>

        <DataGrid x:Name="AuthorsDataGrid" 
                  ItemsSource="{Binding Authors}" 
                  SelectedItem="{Binding SelectedAuthor}"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  Margin="0,0,0,10">
            <DataGrid.Columns>
                <!-- ID (только чтение) -->
                <DataGridTextColumn Header="ID" Binding="{Binding Id}" IsReadOnly="True"/>

                <!-- Имя -->
                <DataGridTextColumn Header="Имя" 
                                    Binding="{Binding FirstName, UpdateSourceTrigger=PropertyChanged}"/>

                <!-- Фамилия -->
                <DataGridTextColumn Header="Фамилия" 
                                    Binding="{Binding LastName, UpdateSourceTrigger=PropertyChanged}"/>

                <!-- Дата рождения с DatePicker -->
                <DataGridTemplateColumn Header="Дата рождения">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding BirthDate, StringFormat='dd/MM/yyyy'}" 
                                       VerticalAlignment="Center"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                    <DataGridTemplateColumn.CellEditingTemplate>
                        <DataTemplate>
                            <DatePicker SelectedDate="{Binding BirthDate}" 
                                        DisplayDateStart="1900-01-01" 
                                        DisplayDateEnd="2100-12-31"
                                        VerticalAlignment="Center"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellEditingTemplate>
                </DataGridTemplateColumn>

                <!-- Страна -->
                <DataGridTextColumn Header="Страна" 
                                    Binding="{Binding Country, UpdateSourceTrigger=PropertyChanged}"/>
            </DataGrid.Columns>
        </DataGrid>
    </DockPanel>
</Window>